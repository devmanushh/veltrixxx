{
  "name": "veltrix",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "web-service",
    "api-service",
    "engine-service",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:services && npm run build:web",
    "build:api": "npm run build:services",
    "build:engine": "npm run build:services",
    "build:server": "npm run build:services",
    "build:services": "tsc",
    "build:worker": "npm run build:engine",
    "dev": "npm run dev:infra && npm run wait:infra && npm run db:generate && npm run db:push && npm run dev:services",
    "dev:services": "concurrently -n web,api,engine -c blue,green,magenta \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:engine\"",
    "dev:infra": "docker compose up -d",
    "wait:infra": "node scripts/wait-for-infra.mjs",
    "dev:web": "cd web-service && npm run dev",
    "dev:api": "cd api-service && npm run dev",
    "dev:engine": "cd engine-service && npm run dev",
    "build:web": "cd web-service && npm run build",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "start": "npm run start:web",
    "start:api": "node dist/api-service/index.js",
    "start:engine": "node dist/engine-service/index.js",
    "start:server": "npm run start:api",
    "start:worker": "npm run start:engine",
    "start:web": "cd web-service && npm run start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "ioredis": "^5.10.1",
    "next": "^16.2.6",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "redis": "^5.12.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.10"
  }
}
