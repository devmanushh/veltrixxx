generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  balance  Float  @default(0)

  orders Order[]
  buyerTrades  Trade[] @relation("BuyerTrades")
  sellerTrades Trade[] @relation("SellerTrades")
  topUps PaymentTopUp[]
  assetBalances AssetBalance[]
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User @relation(fields: [userId], references: [id])

  symbol   String
  price    Float?
  quantity Float
  remaining Float @default(0)
  lockedQuote Float @default(0)
  lockedBase Float @default(0)
  side     String
  type     String
  status   String @default("OPEN")
  createdAt DateTime @default(now())
}

model AssetBalance {
  id     String @id @default(cuid())
  userId String
  user   User @relation(fields: [userId], references: [id])

  asset  String
  free   Float @default(0)
  locked Float @default(0)

  @@unique([userId, asset])
}

model Trade {
  id String @id @default(cuid())

  buyerId  String
  sellerId String

  symbol   String
  price    Float
  quantity Float

  createdAt DateTime @default(now())

  buyer  User @relation("BuyerTrades", fields: [buyerId], references: [id])
  seller User @relation("SellerTrades", fields: [sellerId], references: [id])
}

model Candle {
  id       String @id @default(cuid())
  symbol   String
  interval String
  bucket   DateTime
  open     Float
  high     Float
  low      Float
  close    Float
  volume   Float
  updatedAt DateTime @updatedAt

  @@unique([symbol, interval, bucket])
  @@index([symbol, interval, bucket])
}

model PaymentTopUp {
  id              String   @id @default(cuid())
  stripeSessionId String   @unique
  userId          String
  amountUsd       Float
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  user User @relation(fields: [userId], references: [id])
}
